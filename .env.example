# ==========================================
# Teams Auto Solver - Configuracao
# ==========================================

# Chave secreta do Flask (gere uma aleatoria)
SECRET_KEY=mude-esta-chave-em-producao

# Credenciais do painel admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sua_senha_forte_aqui

# Chave de encriptacao (gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# ==========================================
# Banco de Dados
# ==========================================

# SQLite (local - padrao)
# DATABASE_URI=sqlite:///instance/database.db

# PostgreSQL (Supabase - producao)
# DATABASE_URI=postgresql://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres

# ==========================================
# Redis & Celery (Docker)
# ==========================================

# URL do Redis (para Celery workers)
REDIS_URL=redis://localhost:6379

# Modo de execucao: "celery" (paralelo) ou "local" (serial)
# EXECUTION_MODE=celery

# ==========================================
# Configuracoes Gerais
# ==========================================

# Intervalo padrao de verificacao por cliente (minutos)
DEFAULT_CHECK_INTERVAL=60

# Timezone
TIMEZONE=America/Sao_Paulo

# ==========================================
# Webhook GitHub (deploy automatico)
# ==========================================

# Secret do webhook do GitHub
WEBHOOK_SECRET=seu_webhook_secret

# ==========================================
# Notificacoes WhatsApp (UazAPI)
# ==========================================

# URL da API UazAPI
UAZAPI_URL=

# Token da UazAPI
UAZAPI_TOKEN=

# Numero do admin para alertas (com codigo do pais, ex: 5511999999999)
ADMIN_WHATSAPP=
